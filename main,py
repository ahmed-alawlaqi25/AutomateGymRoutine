wait = WebDriverWait(driver, 2)

def retry(func, retries=7, description=None):
    for i in range(retries):
        print(f"Trying {description}. Attempt: {i + 1}")
        try:
            func()
        except TimeoutException:
            if i == retries -1:
                raise
            sleep(1)

